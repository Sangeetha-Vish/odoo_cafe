generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  color     String
  createdAt DateTime  @default(now()) @map("created_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  tax         Float
  description String
  categoryId  Int         @map("category_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  orderItems  OrderItem[]
  category    Category    @relation(fields: [categoryId], references: [id])

  @@map("products")
}

model Table {
  id          Int         @id @default(autoincrement())
  tableNumber String      @map("table_number")
  seats       Int
  status      TableStatus @default(FREE)
  floor       String      @default("Ground Floor")
  floor_id    Int?
  floors      floors?     @relation(fields: [floor_id], references: [id], onUpdate: NoAction)
  orders      Order[]     @relation("OrderTables")

  @@index([floor_id], map: "idx_tables_floor_id")
  @@map("tables")
}

model Coupon {
  id    Int        @id @default(autoincrement())
  code  String     @unique
  type  CouponType
  value Float

  @@map("coupons")
}

model Order {
  id            Int         @id @default(autoincrement())
  customerName  String?     @map("customer_name")
  notes         String?
  subtotal      Float
  tax           Float
  discount      Float
  total         Float
  paymentMethod String      @map("payment_method")
  status        OrderStatus @default(DRAFT)
  createdAt     DateTime    @default(now()) @map("created_at")
  orderItems    OrderItem[]
  tables        Table[]     @relation("OrderTables")

  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Float
  completed Boolean @default(false)
  status    String  @default("PENDING")
  notes     String?
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Waitlist {
  id           Int      @id @default(autoincrement())
  customerName String   @map("customer_name")
  groupSize    Int      @map("group_size")
  status       String   @default("WAITING")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}

model floors {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now()) @db.Timestamp(6)
  tables     Table[]
}

enum Role {
  ADMIN
  EMPLOYEE
  KITCHEN_EMPLOYEE
  CUSTOMER
}

enum TableStatus {
  FREE
  OCCUPIED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  DRAFT
  TO_COOK
  PREPARING
  COMPLETED
  PAID
}
