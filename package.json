{
  "name": "odoo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate && npm install --prefix client && npm install --prefix admin/admin-module/backend && npm install --prefix admin/admin-module/frontend",
    "dev:frontend": "vite",
    "dev:backend": "cross-env PORT=5002 node server.js",
    "dev:admin-frontend": "cross-env VITE_API_URL=http://localhost:5005 VITE_SOCKET_URL=http://localhost:5005 npm run dev --prefix admin/admin-module/frontend",
    "dev:admin-backend": "cross-env PORT=5005 CLIENT_URL=http://localhost:5175 npm run dev --prefix admin/admin-module/backend",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:admin-frontend\" \"npm run dev:admin-backend\" \"npm run dev:client\"",
    "dev:open": "cross-env BROWSER_OPEN=true npm run dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^5.18.0",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prisma": "^5.18.0",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
